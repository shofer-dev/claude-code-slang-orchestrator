# Regenerate: from the plugin root run `vhs media/demo/slang-workflows.tape`
# media/demo/slang replays a REAL token-free implement-feature.slang run (FakeDispatcher).
Output "media/slang-workflows.gif"
Set Shell "bash"
Set FontSize 20
Set Width 1240
Set Height 500
Set Padding 30
Set TypingSpeed 22ms
Set Theme { "background": "#0c0d14", "foreground": "#e9ecf3", "cursor": "#8b7cf6", "selection": "#2a2740", "black": "#0c0d14", "red": "#d98aa0", "green": "#57c98a", "yellow": "#e9a23b", "blue": "#5fb6d6", "magenta": "#8b7cf6", "cyan": "#5fb6d6", "white": "#e9ecf3", "brightBlack": "#5a6273", "brightRed": "#d98aa0", "brightGreen": "#72c882", "brightYellow": "#f5b544", "brightBlue": "#7cc4e0", "brightMagenta": "#a394f7", "brightCyan": "#7cc4e0", "brightWhite": "#ffffff" }

Hide
Type "export PATH=$PWD/media/demo:$PATH; PS1='\[\e[38;5;141m\]❯ \[\e[0m\]'; clear"
Enter
Sleep 400ms
Show

Sleep 800ms
Type `slang run implement-feature feature=formatBytes`
Sleep 500ms
Enter
Sleep 6500ms
Sleep 1500ms
